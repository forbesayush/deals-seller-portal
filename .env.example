# ─────────────────────────────────────────────────────────────
#  Deals Seller Portal — Environment Variables Reference
#  Copy this to .env (local dev) or set in your hosting dashboard
#  NEVER commit .env with real secrets!
# ─────────────────────────────────────────────────────────────

# ── Backend (FastAPI) ────────────────────────────────────────

# JWT signing secret — MUST be a long random string in production
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret

# Database connection string
# Local dev:    sqlite:///./portal.db
# Production:   postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./portal.db

# Server environment
ENVIRONMENT=development
DEBUG=true


# ── CORS / URLs ──────────────────────────────────────────────

# Your deployed Vercel frontend URL (no trailing slash)
# e.g. https://deals-seller-portal.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# Your deployed backend URL (no trailing slash)
# e.g. https://deals-seller-api.railway.app  OR  your Codespace URL
# This is used by:
#   1. Next.js rewrites (next.config.js) to proxy /api/* calls
#   2. FastAPI CSP header (connect-src) to allow the frontend to call backend
BACKEND_API_URL=https://your-backend.railway.app


# ── Next.js Public ───────────────────────────────────────────

# App display name (available client-side)
NEXT_PUBLIC_APP_NAME=Deals Seller Portal
